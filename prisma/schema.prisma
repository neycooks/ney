generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String
  githubUrl   String
  category    String
  createdAt   DateTime @default(now())
}

model Social {
  id          String   @id @default(cuid())
  name        String
  url         String
  description String
  icon        String
  createdAt   DateTime @default(now())
}
